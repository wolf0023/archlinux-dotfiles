{
    "layer": "top", // Waybar at top layer
    "position": "top", // Waybar position (top|bottom|left|right)
    "mode": "dock", // Waybar mode (dock|overlay)
    // "height": 34, // Waybar height
    // "width": 1280, // Waybar width
    // Choose the order of the modules
    "modules-left": [
        "clock",
        "hyprland/workspaces",
        "tray"
    ],
    "modules-center": ["hyprland/window"],
    "modules-right": [
        "cpu",
        "memory",
        "network",
        "battery",
        "backlight",
        "wireplumber"
    ],
    "hyprland/workspaces": {
        "format": " {id}"
    },
    "hyprland/window": {
        "tooltip": false 
    },
    "tray": {
        "icon-size": 18,
        "spacing": 12
    },
    "cpu": {
        "interval": 2,
        "format": " {usage}%"
    },
    "memory": {
        "interval": 2,
        "format": " {used:.1f}GiB/{total:.1f}GiB",
        "tooltip-format": "Total: {total}GiB\nUsed: {used}GiB ({percentage}%)\nSwap: {swapUsed}GiB ({swapPercentage}%)\nAvailable: {avail}GiB"
    },
    "network": {
        "format": "󰛳  {bandwidthUpBytes} {bandwidthDownBytes}",
        "format-wifi": "  {bandwidthUpBytes} {bandwidthDownBytes}",
        "format-ethernet": "󰈀  {bandwidthUpBytes} {bandwidthDownBytes}",
        "format-disconnected": " Disconnected",
        "tooltip-format": "Interface: {ifname}\nIPAddr: {ipaddr}\nGateway: {gwaddr}\nNetmask(IPv4): {netmask}",
        "tooltip-format-wifi": "Interface: {ifname}\nIPAddr: {ipaddr}\nGateway: {gwaddr}\nNetmask(IPv4): {netmask}\nSSID: {essid}\nSignal Strength: {signalStrength}%"
    },
    "battery": {
        "interval": 30,
        "format": "{icon}{capacity}%",
        "format-unknown": " {capacity}%",
        "format-charging":"󰚥 {capacity}%",
        "format-icons": [" ", " ", " ", " ", " "],
        "states": {
            "warning": 30,
            "critical": 15
        },
        "tooltip-format": "Watt: {power}W\nTime: {timeTo}\nCycles: {cycles}\nHealth: {health}%"
    },
    "wireplumber": {
        "format": "{icon}{volume}%",
        "format-icons" : [" ", " ", " "],
        "format-muted": " 0%",
        "tooltip-format": "Sink: {node_name}\nSource: {source_desc}"
    },
    "backlight": {
        "format": "{icon}{percent}%",
        "format-icons": ["󰃞 ", "󰃟 ", "󰃝 ", "󰃠 "]
    },
    "clock": {
        "format": "󰥔 {:%m/%d(%a) %H:%M}",
        "timezone": "Asia/Tokyo",
        "tooltip": false 
    }
}
